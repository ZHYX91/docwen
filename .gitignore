# ==============================
# 根目录下的隐藏文件
# ==============================
/.*
!/.gitignore

# ==============================
# 日志文件 (忽略所有日志文件)
# ==============================
*.log
*.log.*
*.out
*.tmp
logs/
*.logs/

# ==============================
# Python 打包和编译生成的文件
# ==============================
# 构建目录
/build/
dist/
*.egg-info/
*.egg
*.whl

# 缓存和字节码
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.spec
license.dat

# Cython编译生成的文件
*.c
*.so
*.pyx

# 安装包
*.tar.gz
*.egg-info/
*.dist-info/

# 虚拟环境 (通常也需要忽略)
venv/
env/
.venv/

# ==============================
# 其他常见忽略项
# ==============================
# 编辑器临时文件
*~
*.swp
*.swo
.DS_Store

# 测试覆盖率报告
.coverage
htmlcov/

# ==============================
# Obsidian 插件开发
# ==============================
/obsidian-plugin/

# ==============================
# 私有脚本目录
# ==============================
/scripts/

# ==============================
# OCR模型文件
# ==============================
/models/
